# Garden 3D Environment Configuration
# Copy this to .env and update with your values

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Client Configuration (for Vite)
# Netlify builds should point this to the Railway backend URL.
# http(s) URLs are converted to ws(s) automatically by the client.
VITE_WS_URL=ws://localhost:3000
